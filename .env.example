# Copy this file to .env and fill in your values.

# Required: fine-grained PAT with Copilot Enterprise access.
# For org deployments the per-request user token replaces this for model calls,
# but GITHUB_TOKEN is still needed as the CLI fallback.
GITHUB_TOKEN=ghp_your_token_here

# Dev only: set true to skip ECDSA signature verification.
# NEVER enable in production.
AICRITIC_DEV_MODE=false

# Org deployment: restrict Copilot Extension access to members of this org.
# Leave blank to allow any valid Copilot user.
AICRITIC_ORG=your-org-name

# Optional: path to write structured audit log (one JSON line per request).
# Leave blank to log to stdout only.
AICRITIC_AUDIT_LOG=./logs/audit.jsonl

# Optional: pipeline result cache TTL in seconds (default 86400 = 24 h).
# Set to 0 to disable caching entirely (e.g. in CI).
# AICRITIC_CACHE_TTL=86400

# Optional: override the cache directory (default .aicritic_cache/).
# AICRITIC_CACHE_DIR=.aicritic_cache
