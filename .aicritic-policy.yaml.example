# Copy this file to .aicritic-policy.yaml at your repo root.
# Controls what aicritic ci blocks on in GitHub Actions.

# Risk levels that fail the CI gate and block the PR merge.
# Options: critical, high, medium, low
block_on: [critical, high]

# Analysis profile to use. Leave blank for security_review (default).
# Options: security_review, secrets_scan, error_handling, performance,
#          pr_review, test_quality, migration_safety, dependency_audit,
#          dockerfile_review, iac_review
tool: security_review

# Minimum risk level to include in the report (does not affect blocking).
min_risk: low

# true  = only analyse files changed in this PR (recommended for CI speed)
# false = analyse the entire codebase on every PR
diff_only: true

# Skip the Gemini cross-check stage for faster CI runs (~20s vs ~90s).
# Trade-off: slightly less thorough; recommended for large teams with
# many PRs where speed matters more than maximum coverage.
skip_checker: false

# Minimum test coverage percentage (line rate) required to pass the CI gate.
# Evaluated against the coverage.xml file supplied via --coverage.
# The CI gate exits with code 2 if coverage drops below this floor.
# Comment out (or remove) to disable coverage enforcement.
# Example: require 70% coverage across all analysed files.
# min_coverage: 70
